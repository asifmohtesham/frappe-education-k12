  "font": "Default",
  "html": "{% set school_name = frappe.db.get_single_value('K12 Settings', 'school_display_name') or 'School' %}\n<div style=\"font-family: Arial, sans-serif; padding: 20px; max-width: 800px; margin: 0 auto;\">\n  <h2 style=\"text-align: center;\">{{ school_name }} — Fee Receipt</h2>\n  <hr>\n  <table style=\"width: 100%; margin-bottom: 16px;\">\n    <tr><td><strong>Receipt:</strong></td><td>{{ doc.name }}</td><td><strong>Date:</strong></td><td>{{ doc.posting_date }}</td></tr>\n    <tr><td><strong>Student:</strong></td><td>{{ doc.student_name }}</td><td><strong>Due:</strong></td><td>{{ doc.due_date }}</td></tr>\n    <tr><td><strong>Academic Year:</strong></td><td>{{ doc.academic_year }}</td><td></td><td></td></tr>\n  </table>\n  <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 16px;\">\n    <thead>\n      <tr style=\"background: #f0f0f0;\">\n        <th style=\"text-align: left; padding: 6px; border: 1px solid #ddd;\">Category</th>\n        <th style=\"text-align: right; padding: 6px; border: 1px solid #ddd;\">Amount</th>\n        <th style=\"text-align: right; padding: 6px; border: 1px solid #ddd;\">Discount</th>\n        <th style=\"text-align: right; padding: 6px; border: 1px solid #ddd;\">Total</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% for row in doc.components %}\n      <tr>\n        <td style=\"padding: 6px; border: 1px solid #ddd;\">{{ row.fees_category }}</td>\n        <td style=\"text-align: right; padding: 6px; border: 1px solid #ddd;\">{{ row.amount }}</td>\n        <td style=\"text-align: right; padding: 6px; border: 1px solid #ddd;\">{{ row.discount or '' }}</td>\n        <td style=\"text-align: right; padding: 6px; border: 1px solid #ddd;\">{{ row.total }}</td>\n      </tr>\n      {% endfor %}\n    </tbody>\n  </table>\n  <table style=\"width: 100%; margin-bottom: 16px;\">\n    <tr><td style=\"text-align: right;\"><strong>Grand Total:</strong></td><td style=\"text-align: right; width: 120px;\">{{ doc.grand_total }} {{ doc.currency }}</td></tr>\n    <tr><td style=\"text-align: right;\"><strong>Outstanding:</strong></td><td style=\"text-align: right;\">{{ doc.outstanding_amount }} {{ doc.currency }}</td></tr>\n  </table>\n  {% if doc.outstanding_amount == 0 %}\n  <div style=\"text-align: center;\"><div style=\"font-size: 24px; color: green; border: 3px solid green; padding: 8px; display: inline-block;\">PAID</div></div>\n  {% endif %}\n</div>",
